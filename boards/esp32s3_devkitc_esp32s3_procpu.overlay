/* =========================
 * T3 S3 V1.3
 * ========================= */
#include <zephyr/dt-bindings/pinctrl/esp-pinctrl-common.h>
#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>
#include <zephyr/dt-bindings/pinctrl/esp32s3-gpio-sigmap.h>
#include <zephyr/dt-bindings/lora/sx126x.h>

&flash0 {
    reg = <0x0 DT_SIZE_M(4)>;
};

&psram0 {
    size = <DT_SIZE_M(2)>;
};

/* =========================
 * PINCTRL: pines reales del T3-S3 V1.3
 * DevKit default: MISO=GPIO13, SCLK=GPIO12, MOSI=GPIO11
 * T3-S3 real:     MISO=GPIO3,  SCLK=GPIO5,  MOSI=GPIO6
 * ========================= */
&pinctrl {
    spim2_default: spim2_default {
        group1 {
            pinmux = <SPIM2_MISO_GPIO3>,
                     <SPIM2_SCLK_GPIO5>;
        };
        group2 {
            pinmux = <SPIM2_MOSI_GPIO6>;
            output-low;
        };
    };
};

/* =========================
 * SPI2 + SX1262
 * ========================= */
&spi2 {
    status = "okay";
    pinctrl-0 = <&spim2_default>;
    pinctrl-names = "default";

    cs-gpios = <&gpio0 7 GPIO_ACTIVE_LOW>;

    sx1262: lora@0 {
        compatible = "semtech,sx1262";
        reg = <0>;

        spi-max-frequency = <4000000>;

        reset-gpios = <&gpio0 8  GPIO_ACTIVE_LOW>;
        busy-gpios  = <&gpio1 2  GPIO_ACTIVE_HIGH>;  /* GPIO34 = gpio1 pin 2 */
        dio1-gpios  = <&gpio1 1  GPIO_ACTIVE_HIGH>;  /* GPIO33 = gpio1 pin 1 */

        /* DIO2 controla el switch RF TX/RX */
        dio2-tx-enable;

        /* TCXO 32MHz alimentado por DIO3 a 1.8V */
        dio3-tcxo-voltage = <SX126X_DIO3_TCXO_1V8>;
        tcxo-power-startup-delay-ms = <5>;
    };
};

/* =========================
 * UART0 / GPIO43-44: ya NO se reasignan a I2C.
 * El BME688 se movio a I2C0 (GPIO47/48), por lo que UART0 vuelve a su
 * estado por defecto y los pines 43/44 quedan libres (UART hardware o
 * conector QWIIC). El printk sigue via ROM UART / USB (no depende del
 * driver UART0 de Zephyr).
 * ========================= */

/* =========================
 * PINCTRL: I2C0 en GPIO47 (SDA) y GPIO48 (SCL)
 * Pines del header lateral (JP1), libres y sin funcion de strapping.
 * Sobrescriben el i2c0_default del board (que usaba GPIO1/GPIO2,
 * ocupados por Battery ADC y SD MISO).
 * OJO HARDWARE: requieren pull-ups EXTERNOS de 4.7k a 3V3
 * (el conector QWIIC los traia integrados; el header pelado no).
 * ========================= */
&pinctrl {
    i2c0_bm688: i2c0_bm688 {
        group1 {
            pinmux = <I2C0_SDA_GPIO47>,
                     <I2C0_SCL_GPIO48>;
            bias-pull-up;
            drive-open-drain;
            output-high;
        };
    };
};

/* =========================
 * I2C0 + BM688
 * SD0 -> VCC  => direccion I2C = 0x77  (confirmado por i2c0_scan: ACK 0x77)
 * CS  -> VCC  => modo I2C habilitado (obligatorio)
 * ========================= */
&i2c0 {
    status = "okay";
    pinctrl-0 = <&i2c0_bm688>;
    pinctrl-names = "default";
    /* clock-frequency se hereda del board (100kHz). El driver i2c_esp32
       SOLO admite 100k/400k/1M; un valor distinto mapea a 0 y rompe el init. */

    bme688: bme688@77 {
        compatible = "bosch,bme680";
        reg = <0x77>;
    };
};

/* =========================
 * PINCTRL: UART1 para ZE15-CO en GPIO41 (TX) y GPIO40 (RX)
 * Pines libres del header lateral, sin funcion de strapping.
 * NO se usan 43/44 (UART0/ROM = printk) ni 47/48 (I2C0/BM688).
 * ========================= */
&pinctrl {
    uart1_co: uart1_co {
        group1 {
            pinmux = <UART1_TX_GPIO41>;
            output-high;
        };
        group2 {
            pinmux = <UART1_RX_GPIO40>;
            bias-pull-up;
        };
    };
};

/* =========================
 * UART1 + ZE15-CO (monoxido de carbono)
 * 9600 8N1 (defaults de Zephyr), modo Q&A.
 * Alimentacion del sensor: 5~12V DC (PIN15), NO 3.3V. UART es TTL 3V.
 * Conexion: ESP32 TX(GPIO41) -> sensor RXD(PIN7);
 *           ESP32 RX(GPIO40) <- sensor TXD(PIN8).
 * ========================= */
&uart1 {
    status = "okay";
    current-speed = <9600>;
    pinctrl-0 = <&uart1_co>;
    pinctrl-names = "default";
};

/* =========================
 * ALIAS
 * ========================= */
&{/} {
    aliases {
        lora0       = &sx1262;
        bme688-sensor = &bme688;
        co-uart     = &uart1;
    };
};
